{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark", "system"] },
        "energyLevel": { "type": "string", "enum": ["morning", "night", "balanced"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Represents a course or subject a student is taking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "name", "color"]
    },
    "Event": {
      "title": "Event",
      "description": "Represents a scheduled class, study session, or exam.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "subjectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["class", "exam", "study", "other"] },
        "isRecurring": { "type": "boolean" },
        "recurrenceRule": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "startTime", "endTime", "type"]
    },
    "Task": {
      "title": "Task",
      "description": "Represents a to-do item, assignment, or deadline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "subjectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["todo", "in-progress", "completed"] },
        "isRescheduled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "priority", "status"]
    },
    "Note": {
      "title": "Note",
      "description": "Represents a note taken for a subject.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "subjectId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "content"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Student subjects"
    },
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Scheduled events"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Productivity tasks"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Subject notes"
    }
  }
}
